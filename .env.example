# Database (Supabase PostgreSQL)
# Copy both strings from Supabase → Project Settings → Database → Connection string.
# DATABASE_URL = "Transaction pooler" (port 6543), add ?pgbouncer=true if not present.
# DIRECT_URL = "Session pooler" or "Direct connection" (port 5432) — required for Prisma migrate.
# If you see FATAL: Tenant or user not found: project may be paused (Dashboard → Resume),
# or the password/user was rotated — paste fresh URIs from the dashboard.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# NextAuth & app URL (keep port in sync with `npm run dev`, which uses 3000)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Supabase Storage (for task/comment attachments)
# Get these from Supabase Dashboard → Project Settings → API
# Create a storage bucket named "attachments" (or set SUPABASE_STORAGE_BUCKET)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: custom storage bucket name (default: "attachments")
# SUPABASE_STORAGE_BUCKET=attachments

# Invites (Resend — https://resend.com/api-keys). Restart dev server after changing.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave RESEND_FROM unset to use Navis <onboarding@resend.dev> (works for testing).
# Custom domains need verification in Resend. Free tier may only allow sending to your own email.
# RESEND_FROM=Navis <onboarding@resend.dev>
